# Environment template for factor-stat-arb.
# Copy to .env and fill in real values. .env is gitignored — never commit it.

# ── Database: factor_stat_arb (SEPARATE from trading_system) ──────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
TRADING_DB_NAME=factor_stat_arb

# Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Alpaca (paper only) — use a SEPARATE paper key from trading-system's ──
ALPACA_API_KEY=your_alpaca_paper_key_here
ALPACA_SECRET_KEY=your_alpaca_paper_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ── Application ───────────────────────────────────────────────────────────
APP_NAME=Factor Stat Arb
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
PAPER_TRADING=true

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Prefect: SEPARATE orchestration DB + API port (4201, not 4200) ────────
PREFECT_API_URL=http://localhost:4201/api
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/factor_stat_arb_prefect
